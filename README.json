IndexedDB: "tsukiphonepromax"          ← 与 char.html 共享同一数据库
│
├── objectStore: "worldbook"           ← 独立 store，不干扰 char.html 的 localStorage
│   │
│   ├── key: "wb_pre"     → Entry[]   头部世界书
│   ├── key: "wb_mid"     → Entry[]   中部世界书
│   ├── key: "wb_post"    → Entry[]   尾部世界书
│   ├── key: "wb_global"  → Entry[]   全局世界书
│   └── key: "wb_keyword" → Entry[]   关键词世界书
│
└── (char.html 的数据仍在 localStorage["tsukiphonepromax"]，互不影响)

Entry {
  id        : string    — uid
  title     : string
  content   : string
  keys      : string    — 逗号分隔，如 "forest,精灵"
  priority  : number    — 1–999
  enabled   : boolean
  isKeyword : boolean   — ★ true 当且仅当 section==="keyword" 或 keys 非空
}


IndexedDB: "tsukiphonepromax"  (version 2)
│
├── objectStore: "worldbook"   (out-of-line keys)
│   ├── "wb_pre"         → Entry[]    头部世界书
│   ├── "wb_mid"         → Entry[]    中部世界书
│   ├── "wb_post"        → Entry[]    尾部世界书
│   ├── "wb_global"      → Entry[]    全局世界书
│   ├── "wb_local"       → Entry[]    局部世界书
│   └── "wb_categories"  → string[]   自定义分类列表（不含默认 Online/Offline）
│
├── objectStore: "chars"  (keyPath: "id")   ← worldbook.html 只读
│   └── { id, name, avatar, worldbook, ... }
│
└── objectStore: "users"  (keyPath: "id")   ← 预留
    └── { id, name, avatar, persona, ... }

Entry (pre / mid / post / global) {
  id        : string
  title     : string
  content   : string
  keys      : string     逗号分隔触发词
  priority  : number
  enabled   : boolean
  isKeyword : boolean    ← 自动：keys 非空时为 true
  category  : string     '' | 'Online' | 'Offline' | <custom>
}

Entry (local) {
  ...同上...
  charIds   : string[]   ← 绑定的 char.id 列表
}